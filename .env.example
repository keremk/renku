# Renku Environment Variables
# Copy to .env and fill in your API keys

# AI Provider API Keys
OPENAI_API_KEY=
REPLICATE_API_TOKEN=
FAL_KEY=
WAVESPEED_API_KEY=
ELEVENLABS_API_KEY=
