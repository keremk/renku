{
  "name": "movie-studio",
  "private": true,
  "version": "0.1.0",
  "license": "SEE LICENSE IN ../LICENSE",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && pnpm run build:server && vite build",
    "clean:server": "node -e \"require('node:fs').rmSync('server-dist', { recursive: true, force: true })\"",
    "build:server": "pnpm run clean:server && tsc --project tsconfig.server.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:typecheck": "tsc --project tsconfig.vitest.json --noEmit",
    "check:all": "pnpm lint && pnpm test:typecheck && pnpm test"
  },
  "dependencies": {
    "@gorenku/core": "workspace:*",
    "@tailwindcss/vite": "^4.1.17",
    "@vitejs/plugin-react": "^5.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.556.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.17",
    "tw-animate-css": "^1.4.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^3.2.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "eslint-plugin-tailwindcss": "4.0.0-beta.0",
    "globals": "^16.5.0",
    "jsdom": "^27.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.1",
    "vite": "^7.2.6",
    "vitest": "^3.2.4"
  }
}
