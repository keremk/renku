{
  "name": "ExpertSet",
  "strict": true,
  "schema": {
    "type": "object",
    "properties": {
      "NarratorVoiceName": {
        "type": "string",
        "description": "Chosen ElevenLabs narrator voice name."
      },
      "NarratorVoiceId": {
        "type": "string",
        "description": "Chosen ElevenLabs narrator voice ID."
      },
      "Experts": {
        "type": "array",
        "description": "Recurring documentary experts used across the documentary.",
        "items": {
          "type": "object",
          "properties": {
            "DisplayName": {
              "type": "string",
              "description": "Short on-screen name for the expert."
            },
            "Role": {
              "type": "string",
              "description": "Why this expert is relevant to the topic."
            },
            "VoiceName": {
              "type": "string",
              "description": "Chosen ElevenLabs voice name for this expert."
            },
            "VoiceId": {
              "type": "string",
              "description": "Chosen ElevenLabs voice ID for this expert."
            },
            "PortraitPrompt": {
              "type": "string",
              "description": "Prompt for a single canonical expert portrait in the shared interview environment, suitable as the LTX talking-head anchor image."
            }
          },
          "required": [
            "DisplayName",
            "Role",
            "VoiceName",
            "VoiceId",
            "PortraitPrompt"
          ],
          "additionalProperties": false
        }
      }
    },
    "required": [
      "NarratorVoiceName",
      "NarratorVoiceId",
      "Experts"
    ],
    "additionalProperties": false
  }
}
