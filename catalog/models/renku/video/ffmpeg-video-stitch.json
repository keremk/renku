{
  "input_schema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "ffmpegPath": {
        "type": "string",
        "default": "ffmpeg",
        "description": "Custom FFmpeg binary path (default: 'ffmpeg' from PATH). FFprobe is resolved from the same location when possible."
      },
      "preset": {
        "type": "string",
        "enum": [
          "ultrafast",
          "superfast",
          "veryfast",
          "faster",
          "fast",
          "medium",
          "slow",
          "slower",
          "veryslow"
        ],
        "default": "medium",
        "description": "x264 encoding preset for the stitched output."
      },
      "crf": {
        "type": "integer",
        "minimum": 0,
        "maximum": 51,
        "default": 23,
        "description": "Constant Rate Factor used when re-encoding the stitched output."
      },
      "audioBitrate": {
        "type": "string",
        "pattern": "^\\d+k$",
        "default": "192k",
        "description": "AAC bitrate for stitched clip audio, for example '192k'."
      }
    },
    "additionalProperties": false
  },
  "x-renku-viewer": {
    "version": 1,
    "input": {
      "pointer": "/input_schema",
      "component": "object",
      "label": "Input",
      "order": [
        "preset",
        "crf",
        "audioBitrate",
        "ffmpegPath"
      ],
      "fields": {
        "preset": {
          "pointer": "/input_schema/properties/preset",
          "component": "string-enum",
          "label": "Preset"
        },
        "crf": {
          "pointer": "/input_schema/properties/crf",
          "component": "integer",
          "label": "Crf"
        },
        "audioBitrate": {
          "pointer": "/input_schema/properties/audioBitrate",
          "component": "string",
          "label": "Audio Bitrate"
        },
        "ffmpegPath": {
          "pointer": "/input_schema/properties/ffmpegPath",
          "component": "string",
          "label": "Ffmpeg Path"
        }
      }
    }
  }
}
