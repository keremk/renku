              "item": {
                "pointer": "/properties/timeline/properties/tracks/items",
                "component": "string-enum",
                "label": "Item"
              }
            },
            "masterTracks": {
              "pointer": "/properties/timeline/properties/masterTracks",
              "component": "array-scalar",
              "label": "Master Tracks",
              "item": {
                "pointer": "/properties/timeline/properties/masterTracks/items",
                "component": "string-enum",
