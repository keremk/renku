{
  "input_schema": {
    "required": [
      "prompt",
      "image_urls"
    ],
    "x-fal-order-properties": [
      "prompt",
      "image_urls",
      "image_size",
      "quality",
      "num_images",
      "output_format",
      "sync_mode",
      "mask_url"
    ],
    "title": "EditImageRequest",
    "properties": {
      "prompt": {
        "description": "The prompt for image generation",
        "maxLength": 32000,
        "title": "Prompt",
        "minLength": 2,
        "examples": [
          "Same workers, same beam, same lunch boxes - but they're all on their phones now. One is taking a selfie. One is on a call looking annoyed. Same danger, new priorities. A hard hat has AirPods."
        ],
        "type": "string"
      },
      "sync_mode": {
        "description": "If `True`, the media will be returned as a data URI and the output data won't be available in the request history.",
        "default": false,
        "title": "Sync Mode",
        "type": "boolean"
      },
      "image_size": {
        "anyOf": [
          {
            "$ref": "#/ImageSize"
          },
          {
            "enum": [
              "square_hd",
              "square",
              "portrait_4_3",
              "portrait_16_9",
              "landscape_4_3",
              "landscape_16_9",
              "auto"
            ],
            "type": "string"
          }
        ],
        "default": "auto",
        "title": "Image Size",
        "description": "The size of the generated image. Use 'auto' to infer from input images."
      },
      "quality": {
        "description": "Quality for the generated image",
        "default": "high",
        "enum": [
          "low",
          "medium",
          "high"
        ],
        "title": "Quality",
        "type": "string"
      },
      "num_images": {
        "minimum": 1,
        "default": 1,
        "description": "Number of images to generate",
        "title": "Number of Images",
        "maximum": 4,
        "examples": [
          1
        ],
        "type": "integer"
      },
      "mask_url": {
        "anyOf": [
          {
            "type": "string",
            "format": "uri"
          },
          {
            "type": "null"
          }
        ],
        "title": "Mask Image URL",
        "description": "The URL of the mask image to use for the generation. This indicates what part of the image to edit."
      },
      "image_urls": {
        "description": "The URLs of the images to use as a reference for the generation.",
        "title": "Image URLs",
        "items": {
          "type": "string",
          "format": "uri"
        },
        "examples": [
          [
            "https://v3b.fal.media/files/b/0a8691af/9Se_1_VX1wzTjjTOpWbs9_bb39c2eb-1a41-4749-b1d0-cf134abc8bbf.png"
          ]
        ],
        "type": "array"
      },
      "output_format": {
        "description": "Output format for the images",
        "default": "png",
        "enum": [
          "jpeg",
          "png",
          "webp"
        ],
        "title": "Output Format",
        "type": "string"
      }
    },
    "type": "object"
  },
  "output_schema": {
    "required": [
      "images"
    ],
    "x-fal-order-properties": [
      "images"
    ],
    "title": "EditImageResponse",
    "properties": {
      "images": {
        "description": "The generated images.",
        "title": "Images",
        "items": {
          "$ref": "#/ImageFile"
        },
        "examples": [
          [
            {
              "file_name": "yUt7tifLSbg1WzWWgfj2o.png",
              "height": 1024,
              "content_type": "image/png",
              "url": "https://v3b.fal.media/files/b/0a8691b0/yUt7tifLSbg1WzWWgfj2o.png",
              "width": 1024
            }
          ]
        ],
        "type": "array"
      }
    },
    "type": "object"
  },
  "ImageSize": {
    "x-fal-order-properties": [
      "width",
      "height"
    ],
    "title": "ImageSize",
    "properties": {
      "height": {
        "description": "The height of the generated image.",
        "default": 512,
        "title": "Height",
        "maximum": 14142,
        "exclusiveMinimum": 0,
        "type": "integer"
      },
      "width": {
        "description": "The width of the generated image.",
        "default": 512,
        "title": "Width",
        "maximum": 14142,
        "exclusiveMinimum": 0,
        "type": "integer"
      }
    },
    "type": "object"
  },
  "ImageFile": {
    "required": [
      "url"
    ],
    "x-fal-order-properties": [
      "url",
      "content_type",
      "file_name",
      "file_size",
      "width",
      "height"
    ],
    "title": "ImageFile",
    "properties": {
      "file_name": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "title": "File Name",
        "examples": [
          "z9RV14K95DvU.png"
        ],
        "description": "The name of the file. It will be auto-generated if not provided."
      },
      "height": {
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "title": "Height",
        "description": "The height of the image"
      },
      "content_type": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "title": "Content Type",
        "examples": [
          "image/png"
        ],
        "description": "The mime type of the file."
      },
      "url": {
        "description": "The URL where the file can be downloaded from.",
        "title": "Url",
        "type": "string",
        "format": "uri"
      },
      "width": {
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "title": "Width",
        "description": "The width of the image"
      },
      "file_size": {
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "title": "File Size",
        "examples": [
          4404019
        ],
        "description": "The size of the file in bytes."
      }
    },
    "type": "object"
  },
  "x-renku-viewer": {
    "version": 1,
    "input": {
      "pointer": "/input_schema",
      "component": "object",
      "label": "Input",
      "order": [
        "prompt",
        "sync_mode",
        "image_size",
        "quality",
        "num_images",
        "mask_url",
        "image_urls",
        "output_format"
      ],
      "fields": {
        "prompt": {
          "pointer": "/input_schema/properties/prompt",
          "component": "string",
          "label": "Prompt"
        },
        "sync_mode": {
          "pointer": "/input_schema/properties/sync_mode",
          "component": "boolean",
          "label": "Sync Mode"
        },
        "image_size": {
          "pointer": "/input_schema/properties/image_size",
          "component": "union",
          "label": "Image Size",
          "presentation": "enum-or-dimensions",
          "variants": [
            {
              "id": "variant-1",
              "pointer": "/input_schema/properties/image_size/anyOf/0",
              "schemaPointer": "/ImageSize",
              "component": "object",
              "label": "Custom Size",
              "order": [
                "height",
                "width"
              ],
              "fields": {
                "height": {
                  "pointer": "/ImageSize/properties/height",
                  "component": "integer",
                  "label": "Height"
                },
                "width": {
                  "pointer": "/ImageSize/properties/width",
                  "component": "integer",
                  "label": "Width"
                }
              }
            },
            {
              "id": "variant-2",
              "pointer": "/input_schema/properties/image_size/anyOf/1",
              "component": "string-enum",
              "label": "Preset"
            }
          ],
          "unionEditor": {
            "type": "enum-dimensions",
            "enumVariantId": "variant-2",
            "customVariantId": "variant-1",
            "customSelection": {
              "source": "virtual-option",
              "label": "Custom Size"
            }
          }
        },
        "quality": {
          "pointer": "/input_schema/properties/quality",
          "component": "string-enum",
          "label": "Quality"
        },
        "num_images": {
          "pointer": "/input_schema/properties/num_images",
          "component": "integer",
          "label": "Num Images"
        },
        "mask_url": {
          "pointer": "/input_schema/properties/mask_url",
          "component": "nullable",
          "label": "Mask Url",
          "value": {
            "pointer": "/input_schema/properties/mask_url/anyOf/0",
            "component": "file-uri",
            "label": "Mask Url"
          }
        },
        "image_urls": {
          "pointer": "/input_schema/properties/image_urls",
          "component": "array-file-uri",
          "label": "Image Urls",
          "item": {
            "pointer": "/input_schema/properties/image_urls/items",
            "component": "file-uri",
            "label": "Item"
          }
        },
        "output_format": {
          "pointer": "/input_schema/properties/output_format",
          "component": "string-enum",
          "label": "Output Format"
        }
      }
    }
  }
}
