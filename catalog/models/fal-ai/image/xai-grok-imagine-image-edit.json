{
  "input_schema": {
    "x-fal-order-properties": [
      "prompt",
      "num_images",
      "output_format",
      "sync_mode",
      "image_urls"
    ],
    "type": "object",
    "properties": {
      "prompt": {
        "examples": [
          "Make this scene more realistic but still keep the game vibes"
        ],
        "title": "Prompt",
        "type": "string",
        "maxLength": 8000,
        "description": "Text description of the desired image."
      },
      "num_images": {
        "minimum": 1,
        "title": "Number of Images",
        "type": "integer",
        "maximum": 4,
        "description": "Number of images to generate.",
        "default": 1
      },
      "sync_mode": {
        "title": "Sync Mode",
        "type": "boolean",
        "description": "If `True`, the media will be returned as a data URI and the output data won't be available in the request history.",
        "default": false
      },
      "output_format": {
        "enum": [
          "jpeg",
          "png",
          "webp"
        ],
        "title": "Output Format",
        "type": "string",
        "description": "The format of the generated image.",
        "default": "jpeg"
      },
      "image_urls": {
        "examples": [
          [
            "https://v3b.fal.media/files/b/0a8b911d/Abk8vStrvmSPlzUqI_NN3_image_043.png"
          ]
        ],
        "title": "Image URLs",
        "type": "array",
        "description": "List of URLs of the images to edit. A maximum of 3 images are supported.",
        "items": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "title": "XAIImageEditInput",
    "required": [
      "prompt"
    ]
  },
  "output_schema": {
    "x-fal-order-properties": [
      "images",
      "revised_prompt"
    ],
    "type": "object",
    "properties": {
      "images": {
        "examples": [
          [
            {
              "url": "https://v3b.fal.media/files/b/0a8b911d/XMqiVoO2ECXUZEUYmPl2l.jpg"
            }
          ]
        ],
        "title": "Images",
        "type": "array",
        "description": "The URL of the edited image.",
        "items": {
          "$ref": "#/ImageFile"
        }
      },
      "revised_prompt": {
        "title": "Revised Prompt",
        "type": "string",
        "description": "The enhanced prompt that was used to generate the image."
      }
    },
    "title": "XAIImageEditOutput",
    "required": [
      "images",
      "revised_prompt"
    ]
  },
  "ImageFile": {
    "x-fal-order-properties": [
      "url",
      "content_type",
      "file_name",
      "file_size",
      "width",
      "height"
    ],
    "type": "object",
    "properties": {
      "height": {
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "title": "Height",
        "description": "The height of the image"
      },
      "file_size": {
        "examples": [
          4404019
        ],
        "title": "File Size",
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "description": "The size of the file in bytes."
      },
      "file_name": {
        "examples": [
          "z9RV14K95DvU.png"
        ],
        "title": "File Name",
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "description": "The name of the file. It will be auto-generated if not provided."
      },
      "content_type": {
        "examples": [
          "image/png"
        ],
        "title": "Content Type",
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "description": "The mime type of the file."
      },
      "url": {
        "title": "Url",
        "type": "string",
        "description": "The URL where the file can be downloaded from.",
        "format": "uri"
      },
      "width": {
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "title": "Width",
        "description": "The width of the image"
      }
    },
    "title": "ImageFile",
    "required": [
      "url"
    ]
  },
  "x-renku-viewer": {
    "version": 1,
    "input": {
      "pointer": "/input_schema",
      "component": "object",
      "label": "Input",
      "order": [
        "prompt",
        "num_images",
        "sync_mode",
        "output_format",
        "image_urls"
      ],
      "fields": {
        "prompt": {
          "pointer": "/input_schema/properties/prompt",
          "component": "string",
          "label": "Prompt"
        },
        "num_images": {
          "pointer": "/input_schema/properties/num_images",
          "component": "integer",
          "label": "Num Images"
        },
        "sync_mode": {
          "pointer": "/input_schema/properties/sync_mode",
          "component": "boolean",
          "label": "Sync Mode"
        },
        "output_format": {
          "pointer": "/input_schema/properties/output_format",
          "component": "string-enum",
          "label": "Output Format"
        },
        "image_urls": {
          "pointer": "/input_schema/properties/image_urls",
          "component": "array-file-uri",
          "label": "Image Urls",
          "item": {
            "pointer": "/input_schema/properties/image_urls/items",
            "component": "file-uri",
            "label": "Item"
          }
        }
      }
    }
  }
}
