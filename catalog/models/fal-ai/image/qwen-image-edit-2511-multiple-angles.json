{
  "input_schema": {
    "title": "MultipleAnglesInput",
    "type": "object",
    "properties": {
      "image_size": {
        "anyOf": [
          {
            "$ref": "#/ImageSize"
          },
          {
            "enum": [
              "square_hd",
              "square",
              "portrait_4_3",
              "portrait_16_9",
              "landscape_4_3",
              "landscape_16_9"
            ],
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "title": "Image Size",
        "description": "The size of the generated image. If not provided, the size of the input image will be used."
      },
      "acceleration": {
        "enum": [
          "none",
          "regular"
        ],
        "title": "Acceleration",
        "type": "string",
        "description": "Acceleration level for image generation.",
        "default": "regular"
      },
      "horizontal_angle": {
        "description": "Horizontal rotation angle around the object in degrees. 0°=front view, 90°=right side, 180°=back view, 270°=left side, 360°=front view again.",
        "type": "number",
        "minimum": 0,
        "maximum": 360,
        "title": "Horizontal Angle (Azimuth °)",
        "default": 0
      },
      "enable_safety_checker": {
        "title": "Enable Safety Checker",
        "type": "boolean",
        "description": "Whether to enable the safety checker.",
        "default": true
      },
      "guidance_scale": {
        "minimum": 1,
        "maximum": 20,
        "type": "number",
        "title": "Guidance Scale",
        "description": "The CFG (Classifier Free Guidance) scale.",
        "default": 4.5
      },
      "image_urls": {
        "examples": [
          [
            "https://v3b.fal.media/files/b/0a8973cb/qUbVwDCcMlvX4drBGYB1H.png"
          ]
        ],
        "title": "Image URLs",
        "type": "array",
        "description": "The URL of the image to adjust camera angle for.",
        "items": {
          "type": "string",
          "format": "uri"
        }
      },
      "negative_prompt": {
        "title": "Negative Prompt",
        "type": "string",
        "description": "The negative prompt for the generation",
        "default": ""
      },
      "zoom": {
        "description": "Camera zoom/distance. 0=wide shot (far away), 5=medium shot (normal), 10=close-up (very close).",
        "type": "number",
        "minimum": 0,
        "maximum": 10,
        "title": "Zoom (Distance)",
        "default": 5
      },
      "vertical_angle": {
        "description": "Vertical camera angle in degrees. -30°=low-angle shot (looking up), 0°=eye-level, 30°=elevated, 60°=high-angle, 90°=bird's-eye view (looking down).",
        "type": "number",
        "minimum": -30,
        "maximum": 90,
        "title": "Vertical Angle (Elevation °)",
        "default": 0
      },
      "num_images": {
        "minimum": 1,
        "maximum": 4,
        "type": "integer",
        "title": "Num Images",
        "description": "Number of images to generate",
        "default": 1
      },
      "lora_scale": {
        "minimum": 0,
        "maximum": 4,
        "type": "number",
        "title": "Lora Scale",
        "description": "The scale factor for the LoRA model. Controls the strength of the camera control effect.",
        "default": 1
      },
      "output_format": {
        "enum": [
          "png",
          "jpeg",
          "webp"
        ],
        "title": "Output Format",
        "type": "string",
        "description": "The format of the output image",
        "default": "png"
      },
      "sync_mode": {
        "title": "Sync Mode",
        "type": "boolean",
        "description": "If `True`, the media will be returned as a data URI.",
        "default": false
      },
      "additional_prompt": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "title": "Additional Prompt",
        "description": "Additional text to append to the automatically generated prompt."
      },
      "num_inference_steps": {
        "minimum": 1,
        "maximum": 50,
        "type": "integer",
        "title": "Num Inference Steps",
        "description": "The number of inference steps to perform.",
        "default": 28
      },
      "seed": {
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "title": "Seed",
        "description": "Random seed for reproducibility."
      }
    },
    "description": "Input model for Multiple Angles endpoint - Camera control with precise adjustments using <sks> trigger word.\nPrompt is built automatically from slider values.",
    "x-fal-order-properties": [
      "image_urls",
      "horizontal_angle",
      "vertical_angle",
      "zoom",
      "additional_prompt",
      "lora_scale",
      "image_size",
      "guidance_scale",
      "num_inference_steps",
      "acceleration",
      "negative_prompt",
      "seed",
      "sync_mode",
      "enable_safety_checker",
      "output_format",
      "num_images"
    ],
    "required": [
      "image_urls"
    ],
    "x-renku-constraints": {
      "fields": {
        "image_size": {
          "enum": {
            "values": [
              "square_hd",
              "square",
              "portrait_4_3",
              "portrait_16_9",
              "landscape_4_3",
              "landscape_16_9"
            ],
            "source": "explicit",
            "confidence": "high"
          }
        }
      }
    }
  },
  "output_schema": {
    "title": "MultipleAnglesOutput",
    "type": "object",
    "properties": {
      "prompt": {
        "title": "Prompt",
        "type": "string",
        "description": "The constructed prompt used for generation"
      },
      "images": {
        "examples": [
          [
            {
              "url": "https://v3b.fal.media/files/b/0a8973d9/8Z0xxKdGnoJAWc2tKJ68f.png"
            }
          ]
        ],
        "title": "Images",
        "type": "array",
        "description": "The generated/edited images",
        "items": {
          "$ref": "#/Image"
        }
      },
      "seed": {
        "title": "Seed",
        "type": "integer",
        "description": "The seed used for generation"
      }
    },
    "description": "Output model for Multiple Angles endpoint",
    "x-fal-order-properties": [
      "images",
      "seed",
      "prompt"
    ],
    "required": [
      "images",
      "seed",
      "prompt"
    ]
  },
  "ImageSize": {
    "x-fal-order-properties": [
      "width",
      "height"
    ],
    "type": "object",
    "properties": {
      "height": {
        "maximum": 14142,
        "type": "integer",
        "title": "Height",
        "description": "The height of the generated image.",
        "exclusiveMinimum": 0,
        "default": 512
      },
      "width": {
        "maximum": 14142,
        "type": "integer",
        "title": "Width",
        "description": "The width of the generated image.",
        "exclusiveMinimum": 0,
        "default": 512
      }
    },
    "title": "ImageSize"
  },
  "Image": {
    "description": "Represents an image file.",
    "type": "object",
    "x-fal-order-properties": [
      "url",
      "content_type",
      "file_name",
      "file_size",
      "width",
      "height"
    ],
    "title": "Image",
    "properties": {
      "height": {
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "title": "Height",
        "examples": [
          1024
        ],
        "description": "The height of the image in pixels."
      },
      "file_size": {
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "title": "File Size",
        "examples": [
          4404019
        ],
        "description": "The size of the file in bytes."
      },
      "file_name": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "title": "File Name",
        "examples": [
          "z9RV14K95DvU.png"
        ],
        "description": "The name of the file. It will be auto-generated if not provided."
      },
      "content_type": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "title": "Content Type",
        "examples": [
          "image/png"
        ],
        "description": "The mime type of the file."
      },
      "url": {
        "title": "Url",
        "type": "string",
        "description": "The URL where the file can be downloaded from.",
        "format": "uri"
      },
      "width": {
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "title": "Width",
        "examples": [
          1024
        ],
        "description": "The width of the image in pixels."
      }
    },
    "required": [
      "url"
    ]
  },
  "x-renku-viewer": {
    "version": 1,
    "input": {
      "pointer": "/input_schema",
      "component": "object",
      "label": "Input",
      "order": [
        "image_size",
        "acceleration",
        "horizontal_angle",
        "enable_safety_checker",
        "guidance_scale",
        "image_urls",
        "negative_prompt",
        "zoom",
        "vertical_angle",
        "num_images",
        "lora_scale",
        "output_format",
        "sync_mode",
        "additional_prompt",
        "num_inference_steps",
        "seed"
      ],
      "fields": {
        "image_size": {
          "pointer": "/input_schema/properties/image_size",
          "component": "union",
          "label": "Image Size",
          "presentation": "enum-or-dimensions",
          "variants": [
            {
              "id": "variant-1",
              "pointer": "/input_schema/properties/image_size/anyOf/0",
              "schemaPointer": "/ImageSize",
              "component": "object",
              "label": "Custom Size",
              "order": [
                "height",
                "width"
              ],
              "fields": {
                "height": {
                  "pointer": "/ImageSize/properties/height",
                  "component": "integer",
                  "label": "Height"
                },
                "width": {
                  "pointer": "/ImageSize/properties/width",
                  "component": "integer",
                  "label": "Width"
                }
              }
            },
            {
              "id": "variant-2",
              "pointer": "/input_schema/properties/image_size/anyOf/1",
              "component": "string-enum",
              "label": "Preset"
            },
            {
              "id": "variant-3",
              "pointer": "/input_schema/properties/image_size/anyOf/2",
              "component": "nullable",
              "label": "None"
            }
          ],
          "unionEditor": {
            "type": "enum-dimensions",
            "enumVariantId": "variant-2",
            "customVariantId": "variant-1",
            "customSelection": {
              "source": "virtual-option",
              "label": "Custom Size"
            }
          }
        },
        "acceleration": {
          "pointer": "/input_schema/properties/acceleration",
          "component": "string-enum",
          "label": "Acceleration"
        },
        "horizontal_angle": {
          "pointer": "/input_schema/properties/horizontal_angle",
          "component": "number",
          "label": "Horizontal Angle"
        },
        "enable_safety_checker": {
          "pointer": "/input_schema/properties/enable_safety_checker",
          "component": "boolean",
          "label": "Enable Safety Checker"
        },
        "guidance_scale": {
          "pointer": "/input_schema/properties/guidance_scale",
          "component": "number",
          "label": "Guidance Scale"
        },
        "image_urls": {
          "pointer": "/input_schema/properties/image_urls",
          "component": "array-file-uri",
          "label": "Image Urls",
          "item": {
            "pointer": "/input_schema/properties/image_urls/items",
            "component": "file-uri",
            "label": "Item"
          }
        },
        "negative_prompt": {
          "pointer": "/input_schema/properties/negative_prompt",
          "component": "string",
          "label": "Negative Prompt"
        },
        "zoom": {
          "pointer": "/input_schema/properties/zoom",
          "component": "number",
          "label": "Zoom"
        },
        "vertical_angle": {
          "pointer": "/input_schema/properties/vertical_angle",
          "component": "number",
          "label": "Vertical Angle"
        },
        "num_images": {
          "pointer": "/input_schema/properties/num_images",
          "component": "integer",
          "label": "Num Images"
        },
        "lora_scale": {
          "pointer": "/input_schema/properties/lora_scale",
          "component": "number",
          "label": "Lora Scale"
        },
        "output_format": {
          "pointer": "/input_schema/properties/output_format",
          "component": "string-enum",
          "label": "Output Format"
        },
        "sync_mode": {
          "pointer": "/input_schema/properties/sync_mode",
          "component": "boolean",
          "label": "Sync Mode"
        },
        "additional_prompt": {
          "pointer": "/input_schema/properties/additional_prompt",
          "component": "nullable",
          "label": "Additional Prompt",
          "value": {
            "pointer": "/input_schema/properties/additional_prompt/anyOf/0",
            "component": "string",
            "label": "Additional Prompt"
          }
        },
        "num_inference_steps": {
          "pointer": "/input_schema/properties/num_inference_steps",
          "component": "integer",
          "label": "Num Inference Steps"
        },
        "seed": {
          "pointer": "/input_schema/properties/seed",
          "component": "nullable",
          "label": "Seed",
          "value": {
            "pointer": "/input_schema/properties/seed/anyOf/0",
            "component": "integer",
            "label": "Seed"
          }
        }
      }
    }
  }
}
