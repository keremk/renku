{
  "input_schema": {
    "title": "Flux2FlashEditImageInput",
    "type": "object",
    "properties": {
      "prompt": {
        "examples": [
          "Remove the meat from the hamburger"
        ],
        "title": "Prompt",
        "type": "string",
        "description": "The prompt to edit the image."
      },
      "num_images": {
        "minimum": 1,
        "title": "Number of Images",
        "type": "integer",
        "description": "The number of images to generate.",
        "maximum": 4,
        "default": 1
      },
      "image_size": {
        "anyOf": [
          {
            "$ref": "#/ImageSize"
          },
          {
            "enum": [
              "square_hd",
              "square",
              "portrait_4_3",
              "portrait_16_9",
              "landscape_4_3",
              "landscape_16_9"
            ],
            "type": "string"
          }
        ],
        "title": "Image Size",
        "description": "The size of the image to generate. The width and height must be between 512 and 2048 pixels.",
        "default": "square_hd"
      },
      "output_format": {
        "enum": [
          "jpeg",
          "png",
          "webp"
        ],
        "title": "Output Format",
        "type": "string",
        "description": "The format of the generated image.",
        "default": "png"
      },
      "sync_mode": {
        "title": "Sync Mode",
        "type": "boolean",
        "description": "If `True`, the media will be returned as a data URI and the output data won't be available in the request history.",
        "default": false
      },
      "enable_safety_checker": {
        "title": "Enable Safety Checker",
        "type": "boolean",
        "description": "If set to true, the safety checker will be enabled.",
        "default": true
      },
      "seed": {
        "title": "Seed",
        "type": "integer",
        "description": "The seed to use for the generation. If not provided, a random seed will be used."
      },
      "image_urls": {
        "examples": [
          [
            "https://storage.googleapis.com/falserverless/example_outputs/flux-2-flash-edit-input.png"
          ]
        ],
        "title": "Image URLs",
        "type": "array",
        "description": "The URLs of the images for editing. A maximum of 4 images are allowed, if more are provided, only the first 4 will be used.",
        "items": {
          "type": "string",
          "format": "uri"
        }
      },
      "guidance_scale": {
        "minimum": 0,
        "title": "Guidance Scale",
        "type": "number",
        "description": "Guidance Scale is a measure of how close you want the model to stick to your prompt when looking for a related image to show you.",
        "maximum": 20,
        "default": 2.5
      },
      "enable_prompt_expansion": {
        "title": "Enable Prompt Expansion",
        "type": "boolean",
        "description": "If set to true, the prompt will be expanded for better results.",
        "default": false
      }
    },
    "x-fal-order-properties": [
      "prompt",
      "guidance_scale",
      "seed",
      "image_size",
      "num_images",
      "enable_prompt_expansion",
      "sync_mode",
      "enable_safety_checker",
      "output_format",
      "image_urls"
    ],
    "required": [
      "prompt",
      "image_urls"
    ],
    "x-renku-constraints": {
      "fields": {
        "image_size": {
          "enum": {
            "values": [
              "square_hd",
              "square",
              "portrait_4_3",
              "portrait_16_9",
              "landscape_4_3",
              "landscape_16_9"
            ],
            "source": "explicit",
            "confidence": "high"
          }
        }
      }
    }
  },
  "output_schema": {
    "title": "Flux2FlashEditImageOutput",
    "type": "object",
    "properties": {
      "prompt": {
        "title": "Prompt",
        "type": "string",
        "description": "The prompt used for generating the image."
      },
      "images": {
        "examples": [
          [
            {
              "url": "https://storage.googleapis.com/falserverless/example_outputs/flux-2-flash-edit.png"
            }
          ]
        ],
        "title": "Images",
        "type": "array",
        "description": "The edited images",
        "items": {
          "$ref": "#/ImageFile"
        }
      },
      "seed": {
        "title": "Seed",
        "type": "integer",
        "description": "\n            Seed of the generated Image. It will be the same value of the one passed in the\n            input or the randomly generated that was used in case none was passed.\n        "
      },
      "has_nsfw_concepts": {
        "title": "Has Nsfw Concepts",
        "type": "array",
        "description": "Whether the generated images contain NSFW concepts.",
        "items": {
          "type": "boolean"
        }
      },
      "timings": {
        "title": "Timings",
        "type": "object",
        "additionalProperties": {
          "type": "number"
        }
      }
    },
    "x-fal-order-properties": [
      "images",
      "timings",
      "seed",
      "has_nsfw_concepts",
      "prompt"
    ],
    "required": [
      "images",
      "timings",
      "seed",
      "has_nsfw_concepts",
      "prompt"
    ]
  },
  "ImageSize": {
    "title": "ImageSize",
    "type": "object",
    "properties": {
      "height": {
        "title": "Height",
        "type": "integer",
        "description": "The height of the generated image.",
        "maximum": 14142,
        "exclusiveMinimum": 0,
        "default": 512
      },
      "width": {
        "title": "Width",
        "type": "integer",
        "description": "The width of the generated image.",
        "maximum": 14142,
        "exclusiveMinimum": 0,
        "default": 512
      }
    },
    "x-fal-order-properties": [
      "width",
      "height"
    ]
  },
  "ImageFile": {
    "title": "ImageFile",
    "type": "object",
    "properties": {
      "height": {
        "title": "Height",
        "type": "integer",
        "description": "The height of the image"
      },
      "file_size": {
        "examples": [
          4404019
        ],
        "title": "File Size",
        "type": "integer",
        "description": "The size of the file in bytes."
      },
      "url": {
        "title": "Url",
        "type": "string",
        "description": "The URL where the file can be downloaded from.",
        "format": "uri"
      },
      "width": {
        "title": "Width",
        "type": "integer",
        "description": "The width of the image"
      },
      "file_name": {
        "examples": [
          "z9RV14K95DvU.png"
        ],
        "title": "File Name",
        "type": "string",
        "description": "The name of the file. It will be auto-generated if not provided."
      },
      "content_type": {
        "examples": [
          "image/png"
        ],
        "title": "Content Type",
        "type": "string",
        "description": "The mime type of the file."
      },
      "file_data": {
        "format": "binary",
        "title": "File Data",
        "type": "string",
        "description": "File data"
      }
    },
    "x-fal-order-properties": [
      "url",
      "content_type",
      "file_name",
      "file_size",
      "file_data",
      "width",
      "height"
    ],
    "required": [
      "url"
    ]
  },
  "x-renku-viewer": {
    "version": 1,
    "input": {
      "pointer": "/input_schema",
      "component": "object",
      "label": "Input",
      "order": [
        "prompt",
        "num_images",
        "image_size",
        "output_format",
        "sync_mode",
        "enable_safety_checker",
        "seed",
        "image_urls",
        "guidance_scale",
        "enable_prompt_expansion"
      ],
      "fields": {
        "prompt": {
          "pointer": "/input_schema/properties/prompt",
          "component": "string",
          "label": "Prompt"
        },
        "num_images": {
          "pointer": "/input_schema/properties/num_images",
          "component": "integer",
          "label": "Num Images"
        },
        "image_size": {
          "pointer": "/input_schema/properties/image_size",
          "component": "union",
          "label": "Image Size",
          "presentation": "enum-or-dimensions",
          "variants": [
            {
              "id": "variant-1",
              "pointer": "/input_schema/properties/image_size/anyOf/0",
              "schemaPointer": "/ImageSize",
              "component": "object",
              "label": "Custom Size",
              "order": [
                "height",
                "width"
              ],
              "fields": {
                "height": {
                  "pointer": "/ImageSize/properties/height",
                  "component": "integer",
                  "label": "Height"
                },
                "width": {
                  "pointer": "/ImageSize/properties/width",
                  "component": "integer",
                  "label": "Width"
                }
              }
            },
            {
              "id": "variant-2",
              "pointer": "/input_schema/properties/image_size/anyOf/1",
              "component": "string-enum",
              "label": "Preset"
            }
          ]
        },
        "output_format": {
          "pointer": "/input_schema/properties/output_format",
          "component": "string-enum",
          "label": "Output Format"
        },
        "sync_mode": {
          "pointer": "/input_schema/properties/sync_mode",
          "component": "boolean",
          "label": "Sync Mode"
        },
        "enable_safety_checker": {
          "pointer": "/input_schema/properties/enable_safety_checker",
          "component": "boolean",
          "label": "Enable Safety Checker"
        },
        "seed": {
          "pointer": "/input_schema/properties/seed",
          "component": "integer",
          "label": "Seed"
        },
        "image_urls": {
          "pointer": "/input_schema/properties/image_urls",
          "component": "array-file-uri",
          "label": "Image Urls",
          "item": {
            "pointer": "/input_schema/properties/image_urls/items",
            "component": "file-uri",
            "label": "Item"
          }
        },
        "guidance_scale": {
          "pointer": "/input_schema/properties/guidance_scale",
          "component": "number",
          "label": "Guidance Scale"
        },
        "enable_prompt_expansion": {
          "pointer": "/input_schema/properties/enable_prompt_expansion",
          "component": "boolean",
          "label": "Enable Prompt Expansion"
        }
      }
    }
  }
}
