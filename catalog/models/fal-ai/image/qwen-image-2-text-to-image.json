{
  "input_schema": {
    "x-fal-order-properties": [
      "prompt",
      "negative_prompt",
      "image_size",
      "enable_prompt_expansion",
      "seed",
      "enable_safety_checker",
      "sync_mode",
      "num_images",
      "output_format"
    ],
    "type": "object",
    "properties": {
      "prompt": {
        "examples": [
          "A cute baby koala holding a card says 'Qwen Image 2 is now available on fal' while on a water slider"
        ],
        "description": "Text prompt describing the desired image. Supports Chinese and English.",
        "minLength": 1,
        "title": "Prompt",
        "type": "string"
      },
      "num_images": {
        "minimum": 1,
        "description": "The number of images to generate.",
        "type": "integer",
        "title": "Num Images",
        "maximum": 4,
        "default": 1
      },
      "image_size": {
        "anyOf": [
          {
            "$ref": "#/ImageSize"
          },
          {
            "enum": [
              "square_hd",
              "square",
              "portrait_4_3",
              "portrait_16_9",
              "landscape_4_3",
              "landscape_16_9"
            ],
            "type": "string"
          }
        ],
        "description": "The size of the generated image. Total number of pixels must be between 512x512 and 2048x2048.",
        "title": "Image Size",
        "examples": [
          {
            "height": 2048,
            "width": 2048
          }
        ],
        "default": "square_hd"
      },
      "output_format": {
        "enum": [
          "jpeg",
          "png",
          "webp"
        ],
        "description": "The format of the generated image.",
        "type": "string",
        "title": "Output Format",
        "default": "png"
      },
      "sync_mode": {
        "description": "If `True`, the media will be returned as a data URI and the output data won't be available in the request history.",
        "type": "boolean",
        "title": "Sync Mode",
        "default": false
      },
      "enable_safety_checker": {
        "description": "Enable content moderation for input and output.",
        "type": "boolean",
        "title": "Enable Safety Checker",
        "default": true
      },
      "seed": {
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "description": "Random seed for reproducibility (0-2147483647).",
        "title": "Seed"
      },
      "enable_prompt_expansion": {
        "description": "Enable LLM prompt optimization for better results.",
        "type": "boolean",
        "title": "Enable Prompt Expansion",
        "default": true
      },
      "negative_prompt": {
        "anyOf": [
          {
            "maxLength": 500,
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "description": "Content to avoid in the generated image. Max 500 characters.",
        "title": "Negative Prompt",
        "examples": [
          "low resolution, error, worst quality, low quality, deformed"
        ],
        "default": ""
      }
    },
    "title": "QwenImage2TextToImageInput",
    "required": [
      "prompt"
    ],
    "x-renku-constraints": {
      "fields": {
        "image_size": {
          "enum": {
            "values": [
              "square_hd",
              "square",
              "portrait_4_3",
              "portrait_16_9",
              "landscape_4_3",
              "landscape_16_9"
            ],
            "source": "explicit",
            "confidence": "high"
          }
        }
      }
    }
  },
  "output_schema": {
    "x-fal-order-properties": [
      "images",
      "seed"
    ],
    "type": "object",
    "properties": {
      "images": {
        "examples": [
          [
            {
              "url": "https://v3b.fal.media/files/b/0a90b32f/SuH1rqlI4Us26LffsOWyV_4HJ5a5RO.png"
            }
          ]
        ],
        "description": "Generated images.",
        "type": "array",
        "title": "Images",
        "items": {
          "$ref": "#/File"
        }
      },
      "seed": {
        "examples": [
          42
        ],
        "description": "The seed used for generation",
        "type": "integer",
        "title": "Seed"
      }
    },
    "title": "QwenImage2TextToImageOutput",
    "required": [
      "images",
      "seed"
    ]
  },
  "ImageSize": {
    "x-fal-order-properties": [
      "width",
      "height"
    ],
    "type": "object",
    "properties": {
      "height": {
        "description": "The height of the generated image.",
        "type": "integer",
        "title": "Height",
        "maximum": 14142,
        "exclusiveMinimum": 0,
        "default": 512
      },
      "width": {
        "description": "The width of the generated image.",
        "type": "integer",
        "title": "Width",
        "maximum": 14142,
        "exclusiveMinimum": 0,
        "default": 512
      }
    },
    "title": "ImageSize"
  },
  "File": {
    "x-fal-order-properties": [
      "url",
      "content_type",
      "file_name",
      "file_size"
    ],
    "type": "object",
    "properties": {
      "file_size": {
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "description": "The size of the file in bytes.",
        "title": "File Size",
        "examples": [
          4404019
        ]
      },
      "file_name": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "description": "The name of the file. It will be auto-generated if not provided.",
        "title": "File Name",
        "examples": [
          "z9RV14K95DvU.png"
        ]
      },
      "content_type": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "description": "The mime type of the file.",
        "title": "Content Type",
        "examples": [
          "image/png"
        ]
      },
      "url": {
        "description": "The URL where the file can be downloaded from.",
        "type": "string",
        "title": "Url",
        "format": "uri"
      }
    },
    "title": "File",
    "required": [
      "url"
    ]
  },
  "x-renku-viewer": {
    "version": 1,
    "input": {
      "pointer": "/input_schema",
      "component": "object",
      "label": "Input",
      "order": [
        "prompt",
        "num_images",
        "image_size",
        "output_format",
        "sync_mode",
        "enable_safety_checker",
        "seed",
        "enable_prompt_expansion",
        "negative_prompt"
      ],
      "fields": {
        "prompt": {
          "pointer": "/input_schema/properties/prompt",
          "component": "string",
          "label": "Prompt"
        },
        "num_images": {
          "pointer": "/input_schema/properties/num_images",
          "component": "integer",
          "label": "Num Images"
        },
        "image_size": {
          "pointer": "/input_schema/properties/image_size",
          "component": "union",
          "label": "Image Size",
          "presentation": "enum-or-dimensions",
          "variants": [
            {
              "id": "variant-1",
              "pointer": "/input_schema/properties/image_size/anyOf/0",
              "schemaPointer": "/ImageSize",
              "component": "object",
              "label": "Custom Size",
              "order": [
                "height",
                "width"
              ],
              "fields": {
                "height": {
                  "pointer": "/ImageSize/properties/height",
                  "component": "integer",
                  "label": "Height"
                },
                "width": {
                  "pointer": "/ImageSize/properties/width",
                  "component": "integer",
                  "label": "Width"
                }
              }
            },
            {
              "id": "variant-2",
              "pointer": "/input_schema/properties/image_size/anyOf/1",
              "component": "string-enum",
              "label": "Preset"
            }
          ]
        },
        "output_format": {
          "pointer": "/input_schema/properties/output_format",
          "component": "string-enum",
          "label": "Output Format"
        },
        "sync_mode": {
          "pointer": "/input_schema/properties/sync_mode",
          "component": "boolean",
          "label": "Sync Mode"
        },
        "enable_safety_checker": {
          "pointer": "/input_schema/properties/enable_safety_checker",
          "component": "boolean",
          "label": "Enable Safety Checker"
        },
        "seed": {
          "pointer": "/input_schema/properties/seed",
          "component": "nullable",
          "label": "Seed",
          "value": {
            "pointer": "/input_schema/properties/seed/anyOf/0",
            "component": "integer",
            "label": "Seed"
          }
        },
        "enable_prompt_expansion": {
          "pointer": "/input_schema/properties/enable_prompt_expansion",
          "component": "boolean",
          "label": "Enable Prompt Expansion"
        },
        "negative_prompt": {
          "pointer": "/input_schema/properties/negative_prompt",
          "component": "nullable",
          "label": "Negative Prompt",
          "value": {
            "pointer": "/input_schema/properties/negative_prompt/anyOf/0",
            "component": "string",
            "label": "Negative Prompt"
          }
        }
      }
    }
  }
}
