{
  "input_schema": {
    "title": "Q3ImageToVideoRequest",
    "type": "object",
    "properties": {
      "prompt": {
        "description": "Text prompt for video generation, max 2000 characters",
        "type": "string",
        "examples": [
          "The astronaut waved and the camera moved up."
        ],
        "maxLength": 2000,
        "title": "Prompt",
        "default": ""
      },
      "duration": {
        "minimum": 1,
        "maximum": 16,
        "type": "integer",
        "title": "Duration",
        "description": "Duration of the video in seconds (1-16 for Q3 models)",
        "default": 5
      },
      "resolution": {
        "enum": [
          "360p",
          "540p",
          "720p",
          "1080p"
        ],
        "title": "Resolution",
        "type": "string",
        "description": "Output video resolution. Note: 360p is not available when end_image_url is provided.",
        "default": "720p"
      },
      "image_url": {
        "examples": [
          "https://prod-ss-images.s3.cn-northwest-1.amazonaws.com.cn/vidu-maas/template/image2video.png"
        ],
        "title": "Image Url",
        "type": "string",
        "description": "URL or base64 image to use as the starting frame",
        "format": "uri"
      },
      "seed": {
        "title": "Seed",
        "type": "integer",
        "description": "Random seed for reproducibility. If None, a random seed is chosen."
      },
      "end_image_url": {
        "title": "End Image Url",
        "type": "string",
        "description": "URL of the image to use as the ending frame. When provided, generates a transition video between start and end frames.",
        "format": "uri"
      },
      "audio": {
        "title": "Audio",
        "type": "boolean",
        "description": "Whether to use direct audio-video generation. When true, outputs video with sound (including dialogue and sound effects).",
        "default": true
      }
    },
    "x-fal-order-properties": [
      "prompt",
      "image_url",
      "end_image_url",
      "duration",
      "seed",
      "resolution",
      "audio"
    ],
    "required": [
      "image_url"
    ],
    "x-renku-constraints": {
      "fields": {
        "resolution": {
          "enum": {
            "values": [
              "360p",
              "540p",
              "720p",
              "1080p"
            ],
            "source": "explicit",
            "confidence": "high"
          }
        }
      }
    }
  },
  "output_schema": {
    "title": "Q3ImageToVideoOutput",
    "type": "object",
    "properties": {
      "video": {
        "examples": [
          {
            "url": "https://v3b.fal.media/files/b/0a8c9189/n9z3uUDPqmU2msAtqr25-_output.mp4"
          }
        ],
        "title": "Video",
        "description": "The generated video from image using the Q3 model",
        "allOf": [
          {
            "$ref": "#/File"
          }
        ]
      }
    },
    "x-fal-order-properties": [
      "video"
    ],
    "required": [
      "video"
    ]
  },
  "File": {
    "title": "File",
    "type": "object",
    "properties": {
      "file_size": {
        "examples": [
          4404019
        ],
        "title": "File Size",
        "type": "integer",
        "description": "The size of the file in bytes."
      },
      "file_name": {
        "examples": [
          "z9RV14K95DvU.png"
        ],
        "title": "File Name",
        "type": "string",
        "description": "The name of the file. It will be auto-generated if not provided."
      },
      "content_type": {
        "examples": [
          "image/png"
        ],
        "title": "Content Type",
        "type": "string",
        "description": "The mime type of the file."
      },
      "url": {
        "title": "Url",
        "type": "string",
        "description": "The URL where the file can be downloaded from.",
        "format": "uri"
      },
      "file_data": {
        "format": "binary",
        "title": "File Data",
        "type": "string",
        "description": "File data"
      }
    },
    "x-fal-order-properties": [
      "url",
      "content_type",
      "file_name",
      "file_size",
      "file_data"
    ],
    "required": [
      "url"
    ]
  },
  "x-renku-viewer": {
    "version": 1,
    "input": {
      "pointer": "/input_schema",
      "component": "object",
      "label": "Input",
      "order": [
        "prompt",
        "duration",
        "resolution",
        "image_url",
        "seed",
        "end_image_url",
        "audio"
      ],
      "fields": {
        "prompt": {
          "pointer": "/input_schema/properties/prompt",
          "component": "string",
          "label": "Prompt"
        },
        "duration": {
          "pointer": "/input_schema/properties/duration",
          "component": "integer",
          "label": "Duration"
        },
        "resolution": {
          "pointer": "/input_schema/properties/resolution",
          "component": "string-enum",
          "label": "Resolution"
        },
        "image_url": {
          "pointer": "/input_schema/properties/image_url",
          "component": "file-uri",
          "label": "Image Url"
        },
        "seed": {
          "pointer": "/input_schema/properties/seed",
          "component": "integer",
          "label": "Seed"
        },
        "end_image_url": {
          "pointer": "/input_schema/properties/end_image_url",
          "component": "file-uri",
          "label": "End Image Url"
        },
        "audio": {
          "pointer": "/input_schema/properties/audio",
          "component": "boolean",
          "label": "Audio"
        }
      }
    }
  }
}
