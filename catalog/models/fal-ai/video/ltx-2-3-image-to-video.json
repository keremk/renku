            "url": "https://v3b.fal.media/files/b/0a90dd31/VUCTD0YYJIp_K4qQkkneL_wMVDWNRn.mp4"
          }
        ],
        "description": "The generated video file",
        "$ref": "#/VideoFile"
      }
