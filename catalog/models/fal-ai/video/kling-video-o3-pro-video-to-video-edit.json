{
  "input_schema": {
    "type": "object",
    "title": "O3ProEditVideoV2VInput",
    "required": [
      "prompt",
      "video_url"
    ],
    "properties": {
      "shot_type": {
        "type": "string",
        "description": "The type of multi-shot video generation.",
        "title": "Shot Type",
        "default": "customize",
        "const": "customize"
      },
      "video_url": {
        "type": "string",
        "description": "Reference video URL. Only .mp4/.mov formats, 3-10s duration, 720-2160px resolution, max 200MB.",
        "title": "Video Url",
        "examples": [
          "https://storage.googleapis.com/falserverless/example_inputs/kling-o3/pro-v2v-edit/video_reference.mp4"
        ],
        "_fal_ui_field": "video",
        "limit_description": "Max file size: 200.0MB, Min width: 720px, Min height: 720px, Max width: 2160px, Max height: 2160px, Min duration: 3.0s, Max duration: 10.05s, Min FPS: 24.0, Max FPS: 60.0, Timeout: 30.0s",
        "x-fal": {
          "min_width": 720,
          "max_width": 2160,
          "min_height": 720,
          "max_fps": 60,
          "min_fps": 24,
          "timeout": 30,
          "max_file_size": 209715200,
          "min_duration": 3,
          "max_duration": 10.05,
          "max_height": 2160
        },
        "format": "uri"
      },
      "keep_audio": {
        "type": "boolean",
        "description": "Whether to keep the original audio from the reference video. ",
        "title": "Keep Audio",
        "default": true
      },
      "image_urls": {
        "description": "Reference images for style/appearance. Reference in prompt as @Image1, @Image2, etc. Maximum 4 total (elements + reference images) when using video.",
        "title": "Image Urls",
        "anyOf": [
          {
            "type": "array",
            "items": {
              "type": "string",
              "_fal_ui_field": "image",
              "limit_description": "Max file size: 10.0MB, Min width: 300px, Min height: 300px, Min aspect ratio: 0.40, Max aspect ratio: 2.50, Timeout: 20.0s",
              "ui": {
                "field": "image"
              },
              "x-fal": {
                "min_aspect_ratio": 0.4,
                "max_aspect_ratio": 2.5,
                "min_height": 300,
                "max_file_size": 10485760,
                "min_width": 300,
                "timeout": 20
              },
              "format": "uri"
            }
          },
          {
            "type": "null"
          }
        ],
        "examples": [
          [
            "https://storage.googleapis.com/falserverless/example_inputs/kling-o3/pro-v2v-edit/image_url1.jpg"
          ]
        ]
      },
      "elements": {
        "description": "Elements (characters/objects) to include. Reference in prompt as @Element1, @Element2.",
        "title": "Elements",
        "anyOf": [
          {
            "type": "array",
            "items": {
              "$ref": "#/KlingV3ImageElementInput"
            }
          },
          {
            "type": "null"
          }
        ],
        "examples": [
          [
            {
              "reference_image_urls": [
                "https://storage.googleapis.com/falserverless/example_inputs/kling-o3/pro-v2v-edit/element1_reference1.png"
              ],
              "frontal_image_url": "https://storage.googleapis.com/falserverless/example_inputs/kling-o3/pro-v2v-edit/element1_front.png"
            }
          ]
        ]
      },
      "prompt": {
        "type": "string",
        "description": "Text prompt for video generation. Reference video as @Video1.",
        "title": "Prompt",
        "maxLength": 2500,
        "examples": [
          "Change environment to be fully snow as @Image1. Replace animal with @Element1"
        ]
      }
    },
    "x-fal-order-properties": [
      "prompt",
      "video_url",
      "image_urls",
      "keep_audio",
      "elements",
      "shot_type"
    ]
  },
  "output_schema": {
    "type": "object",
    "title": "O3ProEditV2VOutput",
    "required": [
      "video"
    ],
    "properties": {
      "video": {
        "description": "The generated video.",
        "$ref": "#/File",
        "examples": [
          {
            "content_type": "video/mp4",
            "file_size": 4322769,
            "url": "https://storage.googleapis.com/falserverless/example_outputs/kling-o3/pro-v2v-edit/output.mp4",
            "file_name": "output.mp4"
          }
        ]
      }
    },
    "x-fal-order-properties": [
      "video"
    ]
  },
  "KlingV3ImageElementInput": {
    "type": "object",
    "title": "KlingV3ImageElementInput",
    "properties": {
      "reference_image_urls": {
        "description": "Additional reference images from different angles. 1-3 images supported. At least one image is required.",
        "title": "Reference Image Urls",
        "anyOf": [
          {
            "type": "array",
            "items": {
              "type": "string",
              "_fal_ui_field": "image",
              "limit_description": "Max file size: 10.0MB, Min width: 300px, Min height: 300px, Min aspect ratio: 0.40, Max aspect ratio: 2.50, Timeout: 20.0s",
              "ui": {
                "field": "image"
              },
              "x-fal": {
                "min_aspect_ratio": 0.4,
                "max_aspect_ratio": 2.5,
                "min_height": 300,
                "max_file_size": 10485760,
                "min_width": 300,
                "timeout": 20
              },
              "format": "uri"
            }
          },
          {
            "type": "null"
          }
        ]
      },
      "frontal_image_url": {
        "description": "The frontal image of the element (main view).",
        "title": "Frontal Image Url",
        "anyOf": [
          {
            "type": "string",
            "limit_description": "Max file size: 10.0MB, Min width: 300px, Min height: 300px, Min aspect ratio: 0.40, Max aspect ratio: 2.50, Timeout: 20.0s",
            "ui": {
              "field": "image"
            },
            "x-fal": {
              "min_aspect_ratio": 0.4,
              "max_aspect_ratio": 2.5,
              "min_height": 300,
              "max_file_size": 10485760,
              "min_width": 300,
              "timeout": 20
            },
            "format": "uri"
          },
          {
            "type": "null"
          }
        ]
      }
    },
    "x-fal-order-properties": [
      "frontal_image_url",
      "reference_image_urls"
    ]
  },
  "File": {
    "type": "object",
    "title": "File",
    "required": [
      "url"
    ],
    "properties": {
      "content_type": {
        "description": "The mime type of the file.",
        "title": "Content Type",
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "examples": [
          "image/png"
        ]
      },
      "file_size": {
        "description": "The size of the file in bytes.",
        "title": "File Size",
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "examples": [
          4404019
        ]
      },
      "url": {
        "type": "string",
        "description": "The URL where the file can be downloaded from.",
        "title": "Url",
        "format": "uri"
      },
      "file_name": {
        "description": "The name of the file. It will be auto-generated if not provided.",
        "title": "File Name",
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "examples": [
          "z9RV14K95DvU.png"
        ]
      }
    },
    "x-fal-order-properties": [
      "url",
      "content_type",
      "file_name",
      "file_size"
    ]
  },
  "x-renku-viewer": {
    "version": 1,
    "input": {
      "pointer": "/input_schema",
      "component": "object",
      "label": "Input",
      "order": [
        "shot_type",
        "video_url",
        "keep_audio",
        "image_urls",
        "elements",
        "prompt"
      ],
      "fields": {
        "shot_type": {
          "pointer": "/input_schema/properties/shot_type",
          "component": "string",
          "label": "Shot Type"
        },
        "video_url": {
          "pointer": "/input_schema/properties/video_url",
          "component": "file-uri",
          "label": "Video Url"
        },
        "keep_audio": {
          "pointer": "/input_schema/properties/keep_audio",
          "component": "boolean",
          "label": "Keep Audio"
        },
        "image_urls": {
          "pointer": "/input_schema/properties/image_urls",
          "component": "nullable",
          "label": "Image Urls",
          "value": {
            "pointer": "/input_schema/properties/image_urls/anyOf/0",
            "component": "array-file-uri",
            "label": "Image Urls",
            "item": {
              "pointer": "/input_schema/properties/image_urls/anyOf/0/items",
              "component": "file-uri",
              "label": "Item"
            }
          }
        },
        "elements": {
          "pointer": "/input_schema/properties/elements",
          "component": "nullable",
          "label": "Elements",
          "value": {
            "pointer": "/input_schema/properties/elements/anyOf/0",
            "component": "array-object-cards",
            "label": "Elements",
            "item": {
              "pointer": "/input_schema/properties/elements/anyOf/0/items",
              "component": "object",
              "label": "Item",
              "order": [
                "reference_image_urls",
                "frontal_image_url"
              ],
              "fields": {
                "reference_image_urls": {
                  "pointer": "/input_schema/properties/elements/anyOf/0/items/properties/reference_image_urls",
                  "component": "nullable",
                  "label": "Reference Image Urls",
                  "value": {
                    "pointer": "/input_schema/properties/elements/anyOf/0/items/properties/reference_image_urls/anyOf/0",
                    "component": "array-file-uri",
                    "label": "Reference Image Urls",
                    "item": {
                      "pointer": "/input_schema/properties/elements/anyOf/0/items/properties/reference_image_urls/anyOf/0/items",
                      "component": "file-uri",
                      "label": "Item"
                    }
                  }
                },
                "frontal_image_url": {
                  "pointer": "/input_schema/properties/elements/anyOf/0/items/properties/frontal_image_url",
                  "component": "nullable",
                  "label": "Frontal Image Url",
                  "value": {
                    "pointer": "/input_schema/properties/elements/anyOf/0/items/properties/frontal_image_url/anyOf/0",
                    "component": "file-uri",
                    "label": "Frontal Image Url"
                  }
                }
              }
            }
          }
        },
        "prompt": {
          "pointer": "/input_schema/properties/prompt",
          "component": "string",
          "label": "Prompt"
        }
      }
    }
  }
}
