{
  "input_schema": {
    "x-fal-order-properties": [
      "prompt",
      "reference_image_urls",
      "duration",
      "aspect_ratio",
      "resolution"
    ],
    "type": "object",
    "properties": {
      "prompt": {
        "examples": [
          "A @Image1 running through a sunlit meadow, cinematic slow motion"
        ],
        "maxLength": 4096,
        "type": "string",
        "description": "Text prompt describing the video to generate. Use @Image1, @Image2, etc. to reference specific images from reference_image_urls in order.",
        "title": "Prompt"
      },
      "duration": {
        "description": "Video duration in seconds.",
        "type": "integer",
        "minimum": 1,
        "maximum": 10,
        "title": "Duration",
        "default": 8
      },
      "resolution": {
        "enum": [
          "480p",
          "720p"
        ],
        "description": "Resolution of the output video.",
        "type": "string",
        "title": "Resolution",
        "default": "480p"
      },
      "reference_image_urls": {
        "description": "One or more reference image URLs to guide the video generation as style and content references. Reference in prompt as @Image1, @Image2, etc. Maximum 7 images.",
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "string",
          "format": "uri"
        },
        "examples": [
          [
            "https://v3b.fal.media/files/b/0a8b90e0/BFLE9VDlZqsryU-UA3BoD_image_004.png"
          ]
        ],
        "title": "Reference Image URLs",
        "maxItems": 7
      },
      "aspect_ratio": {
        "enum": [
          "16:9",
          "4:3",
          "3:2",
          "1:1",
          "2:3",
          "3:4",
          "9:16"
        ],
        "description": "Aspect ratio of the generated video.",
        "type": "string",
        "title": "Aspect Ratio",
        "default": "16:9"
      }
    },
    "title": "XAIReferenceToVideoInput",
    "required": [
      "prompt",
      "reference_image_urls"
    ]
  },
  "output_schema": {
    "x-fal-order-properties": [
      "video"
    ],
    "type": "object",
    "properties": {
      "video": {
        "examples": [
          {
            "height": 720,
            "duration": 8,
            "url": "https://v3b.fal.media/files/b/0a8b90e4/r2v_output.mp4",
            "fps": 24,
            "width": 1280,
            "file_name": "r2v_output.mp4",
            "num_frames": 192,
            "content_type": "video/mp4"
          }
        ],
        "description": "The generated video.",
        "$ref": "#/VideoFile"
      }
    },
    "title": "XAIReferenceToVideoOutput",
    "required": [
      "video"
    ]
  },
  "VideoFile": {
    "x-fal-order-properties": [
      "url",
      "content_type",
      "file_name",
      "file_size",
      "width",
      "height",
      "fps",
      "duration",
      "num_frames"
    ],
    "type": "object",
    "properties": {
      "file_size": {
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "description": "The size of the file in bytes.",
        "examples": [
          4404019
        ],
        "title": "File Size"
      },
      "duration": {
        "anyOf": [
          {
            "type": "number"
          },
          {
            "type": "null"
          }
        ],
        "description": "The duration of the video",
        "title": "Duration"
      },
      "height": {
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "description": "The height of the video",
        "title": "Height"
      },
      "url": {
        "description": "The URL where the file can be downloaded from.",
        "type": "string",
        "title": "Url",
        "format": "uri"
      },
      "width": {
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "description": "The width of the video",
        "title": "Width"
      },
      "fps": {
        "anyOf": [
          {
            "type": "number"
          },
          {
            "type": "null"
          }
        ],
        "description": "The FPS of the video",
        "title": "Fps"
      },
      "file_name": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "description": "The name of the file. It will be auto-generated if not provided.",
        "examples": [
          "z9RV14K95DvU.png"
        ],
        "title": "File Name"
      },
      "num_frames": {
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "description": "The number of frames in the video",
        "title": "Num Frames"
      },
      "content_type": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ],
        "description": "The mime type of the file.",
        "examples": [
          "image/png"
        ],
        "title": "Content Type"
      }
    },
    "title": "VideoFile",
    "required": [
      "url"
    ]
  },
  "x-renku-viewer": {
    "version": 1,
    "input": {
      "pointer": "/input_schema",
      "component": "object",
      "label": "Input",
      "order": [
        "prompt",
        "duration",
        "resolution",
        "reference_image_urls",
        "aspect_ratio"
      ],
      "fields": {
        "prompt": {
          "pointer": "/input_schema/properties/prompt",
          "component": "string",
          "label": "Prompt"
        },
        "duration": {
          "pointer": "/input_schema/properties/duration",
          "component": "integer",
          "label": "Duration"
        },
        "resolution": {
          "pointer": "/input_schema/properties/resolution",
          "component": "string-enum",
          "label": "Resolution"
        },
        "reference_image_urls": {
          "pointer": "/input_schema/properties/reference_image_urls",
          "component": "array-file-uri",
          "label": "Reference Image Urls",
          "item": {
            "pointer": "/input_schema/properties/reference_image_urls/items",
            "component": "file-uri",
            "label": "Item"
          }
        },
        "aspect_ratio": {
          "pointer": "/input_schema/properties/aspect_ratio",
          "component": "string-enum",
          "label": "Aspect Ratio"
        }
      }
    }
  }
}
