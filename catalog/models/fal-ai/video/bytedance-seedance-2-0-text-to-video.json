        "title": "Content Type",
        "description": "The mime type of the file."
      },
      "file_size": {
        "anyOf": [
          {
            "type": "integer"
          },
          {
            "type": "null"
          }
        ],
        "examples": [
          4404019
        ],
        "title": "File Size",
        "description": "The size of the file in bytes."
      }
    },
    "x-fal-order-properties": [
      "url",
      "content_type",
      "file_name",
      "file_size"
    ],
    "required": [
