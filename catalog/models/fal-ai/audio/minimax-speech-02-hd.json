          ],
          "fields": {
            "format": {
              "pointer": "/AudioSetting/properties/format",
              "component": "string-enum",
              "label": "Format"
            },
            "sample_rate": {
              "pointer": "/AudioSetting/properties/sample_rate",
              "component": "integer",
              "label": "Sample Rate"
            },
            "channel": {
              "pointer": "/AudioSetting/properties/channel",
              "component": "integer",
              "label": "Channel"
            },
            "bitrate": {
              "pointer": "/AudioSetting/properties/bitrate",
              "component": "integer",
              "label": "Bitrate"
            }
          }
        }
      }
    }
  }
}
