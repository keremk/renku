{
  "input_schema": {
    "type": "object",
    "title": "Input",
    "properties": {
      "lyrics": {
        "type": "string",
        "title": "Lyrics",
        "default": "",
        "x-order": 0,
        "description": "Lyrics for the song. Use \\n to separate lines. You can add structure tags like [Intro], [Verse], [Pre Chorus], [Chorus], [Interlude], [Bridge], [Outro], [Post Chorus], [Transition], [Break], [Hook], [Build Up], [Inst], [Solo] to control the arrangement. 1-3500 characters. Not required when is_instrumental is true."
      },
      "prompt": {
        "type": "string",
        "title": "Prompt",
        "default": "",
        "x-order": 1,
        "description": "A description of the music style, mood, and scenario. For example: 'Pop, melancholic, perfect for a rainy night'. 0-2000 characters. Required when is_instrumental is true."
      },
      "bitrate": {
        "allOf": [
          {
            "$ref": "#/bitrate"
          }
        ],
        "default": 256000,
        "x-order": 5,
        "description": "Bitrate for the generated music"
      },
      "sample_rate": {
        "allOf": [
          {
            "$ref": "#/sample_rate"
          }
        ],
        "default": 44100,
        "x-order": 4,
        "description": "Sample rate for the generated music"
      },
      "audio_format": {
        "allOf": [
          {
            "$ref": "#/audio_format"
          }
        ],
        "default": "mp3",
        "x-order": 6,
        "description": "Audio format for the output"
      },
      "is_instrumental": {
        "type": "boolean",
        "title": "Is Instrumental",
        "default": false,
        "x-order": 2,
        "description": "Generate instrumental music without vocals. When true, prompt is required and lyrics are not needed."
      },
      "lyrics_optimizer": {
        "type": "boolean",
        "title": "Lyrics Optimizer",
        "default": false,
        "x-order": 3,
        "description": "Automatically generate lyrics from the prompt when lyrics are empty."
      }
    }
  },
  "output_schema": {
    "type": "string",
    "title": "Output",
    "format": "uri"
  },
  "Status": {
    "enum": [
      "starting",
      "processing",
      "succeeded",
      "canceled",
      "failed"
    ],
    "type": "string",
    "title": "Status",
    "description": "An enumeration."
  },
  "bitrate": {
    "enum": [
      32000,
      64000,
      128000,
      256000
    ],
    "type": "integer",
    "title": "bitrate",
    "description": "An enumeration."
  },
  "sample_rate": {
    "enum": [
      16000,
      24000,
      32000,
      44100
    ],
    "type": "integer",
    "title": "sample_rate",
    "description": "An enumeration."
  },
  "audio_format": {
    "enum": [
      "mp3",
      "wav",
      "pcm"
    ],
    "type": "string",
    "title": "audio_format",
    "description": "An enumeration."
  },
  "ValidationError": {
    "type": "object",
    "title": "ValidationError",
    "required": [
      "loc",
      "msg",
      "type"
    ],
    "properties": {
      "loc": {
        "type": "array",
        "items": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "integer"
            }
          ]
        },
        "title": "Location"
      },
      "msg": {
        "type": "string",
        "title": "Message"
      },
      "type": {
        "type": "string",
        "title": "Error Type"
      }
    }
  },
  "PredictionRequest": {
    "type": "object",
    "title": "PredictionRequest",
    "properties": {
      "id": {
        "type": "string",
        "title": "Id"
      },
      "input": {
        "$ref": "#/Input"
      }
    }
  },
  "PredictionResponse": {
    "type": "object",
    "title": "PredictionResponse",
    "properties": {
      "id": {
        "type": "string",
        "title": "Id"
      },
      "logs": {
        "type": "string",
        "title": "Logs"
      },
      "error": {
        "type": "string",
        "title": "Error"
      },
      "input": {
        "$ref": "#/Input"
      },
      "output": {
        "$ref": "#/Output"
      },
      "status": {
        "type": "string",
        "title": "Status"
      },
      "metrics": {
        "type": "object",
        "title": "Metrics"
      },
      "version": {
        "type": "string",
        "title": "Version"
      },
      "created_at": {
        "type": "string",
        "title": "Created At",
        "format": "date-time"
      },
      "started_at": {
        "type": "string",
        "title": "Started At",
        "format": "date-time"
      },
      "completed_at": {
        "type": "string",
        "title": "Completed At",
        "format": "date-time"
      }
    }
  },
  "HTTPValidationError": {
    "type": "object",
    "title": "HTTPValidationError",
    "properties": {
      "detail": {
        "type": "array",
        "items": {
          "$ref": "#/ValidationError"
        },
        "title": "Detail"
      }
    }
  },
  "x-renku-viewer": {
    "version": 1,
    "input": {
      "pointer": "/input_schema",
      "component": "object",
      "label": "Input",
      "order": [
        "lyrics",
        "prompt",
        "bitrate",
        "sample_rate",
        "audio_format",
        "is_instrumental",
        "lyrics_optimizer"
      ],
      "fields": {
        "lyrics": {
          "pointer": "/input_schema/properties/lyrics",
          "component": "string",
          "label": "Lyrics"
        },
        "prompt": {
          "pointer": "/input_schema/properties/prompt",
          "component": "string",
          "label": "Prompt"
        },
        "bitrate": {
          "pointer": "/input_schema/properties/bitrate",
          "schemaPointer": "/bitrate",
          "component": "integer",
          "label": "Bitrate"
        },
        "sample_rate": {
          "pointer": "/input_schema/properties/sample_rate",
          "schemaPointer": "/sample_rate",
          "component": "integer",
          "label": "Sample Rate"
        },
        "audio_format": {
          "pointer": "/input_schema/properties/audio_format",
          "schemaPointer": "/audio_format",
          "component": "string-enum",
          "label": "Audio Format"
        },
        "is_instrumental": {
          "pointer": "/input_schema/properties/is_instrumental",
          "component": "boolean",
          "label": "Is Instrumental"
        },
        "lyrics_optimizer": {
          "pointer": "/input_schema/properties/lyrics_optimizer",
          "component": "boolean",
          "label": "Lyrics Optimizer"
        }
      }
    }
  }
}
