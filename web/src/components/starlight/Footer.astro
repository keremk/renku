---
import DefaultFooter from '@astrojs/starlight/components/Footer.astro';
import CookieBanner from '../CookieBanner.astro';
import ScrollDepthTracker from '../ScrollDepthTracker.astro';
---

<DefaultFooter />

<div class="starlight-cookie-settings">
  <button
    type="button"
    data-cookie-settings-trigger
    class="starlight-cookie-settings-link"
  >
    Cookie settings
  </button>
</div>

<CookieBanner />
<ScrollDepthTracker />

<style>
  @layer starlight.core {
    .starlight-cookie-settings {
      margin: 0.5rem 0 1.5rem;
      text-align: center;
    }

    .starlight-cookie-settings-link {
      border: none;
      background: none;
      color: var(--sl-color-gray-3);
      font: inherit;
      font-size: var(--sl-text-sm);
      text-decoration: underline;
      text-underline-offset: 3px;
      cursor: pointer;
    }

    .starlight-cookie-settings-link:hover {
      color: var(--sl-color-white);
    }
  }
</style>
