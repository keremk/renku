---
import IconArrowRight from './icons/IconArrowRight.astro';
import IconDownload from './icons/IconDownload.astro';

interface Props {
  title?: string;
  tagline?: string;
  videoUrl?: string;
}

const {
  title = 'Build Tool For AI-Generated Videos',
  tagline = 'Go beyond the 10 seconds. Create videos using AI generative models, with automatic prompt generation, and cost effective incremental builds.',
  videoUrl = 'https://videos.gorenku.com/videos/renku-hero-v1.mp4',
} = Astro.props;

const titleParts = title.split(' ');
const gradientTitle = titleParts.slice(0, 3).join(' ');
const solidTitle = titleParts.slice(3).join(' ');

const installPageUrl = '/install/';
---

<section class="hero-section">
  <div class="hero-bg"></div>
  <div class="hero-grid"></div>

  <div class="hero-layout" data-hero-section>
    <div class="hero-media-shell">
      <div class="hero-video-frame">
        <video
          data-hero-video
          class="hero-video"
          muted
          loop
          playsinline
          preload="none"
          aria-label="Renku product video"
        >
          <source src={videoUrl} type="video/mp4" />
        </video>
      </div>
    </div>

    <div class="hero-copy">
      <!-- Title with gradient text -->
      <h1 class="hero-title">
        <span class="hero-title-gradient">{gradientTitle}</span>
        <br />
        <span class="hero-title-solid">{solidTitle}</span>
      </h1>

      <!-- Tagline -->
      <p class="hero-tagline">
        {tagline}
      </p>

      <!-- CTA Buttons -->
      <div class="hero-actions hero-actions-desktop">
        <a href={installPageUrl} class="hero-btn-primary" data-ph-capture="install_cta_clicked" data-ph-props='{"location":"hero"}'>
          Install
          <IconDownload class="ml-2 h-5 w-5" />
        </a>
        <!--
          Temporary while DMG signing is unavailable:
          <a href="https://downloads.gorenku.com/desktop/stable/darwin/arm64/Renku-latest-arm64.dmg" class="hero-btn-primary" target="_blank" rel="noreferrer">
            Download for macOS
            <IconDownload class="ml-2 h-5 w-5" />
          </a>
        -->
        <a href="https://discord.gg/fYceuVcv" class="hero-btn-secondary" data-ph-capture="quickstart_cta_clicked" data-ph-props='{"location":"hero"}' target="_blank" rel="noreferrer">
          Join Our Community
          <IconArrowRight class="ml-2 h-5 w-5" />
        </a>
      </div>

      <p class="hero-platform-note">
        Run <code>renku launch</code> after install to open onboarding and the local viewer experience.
      </p>

      <div class="hero-mobile-cta">
        <p class="hero-mobile-note">
          Renku runs on desktop. Use install instructions for macOS, Linux, and Windows with WSL.
        </p>
        <div class="hero-actions hero-actions-mobile">
          <a href={installPageUrl} class="hero-btn-primary" data-ph-capture="install_cta_clicked" data-ph-props='{"location":"hero_mobile"}'>
            View install options
            <IconArrowRight class="ml-2 h-5 w-5" />
          </a>
          <a href="/docs/" class="hero-btn-secondary" data-ph-capture="quickstart_cta_clicked" data-ph-props='{"location":"hero_mobile","destination":"docs"}'>
            Read the docs
            <IconArrowRight class="ml-2 h-5 w-5" />
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="hero-scroll-hint" data-scroll-hint aria-hidden="true">
    <a href="#features" class="scroll-indicator">
      <svg width="22" height="12" viewBox="0 0 14 8" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M1 1l6 6 6-6"/>
      </svg>
    </a>
  </div>
</section>

<script lang="ts">
  const heroSection = document.querySelector('[data-hero-section]');
  const heroVideo = heroSection?.querySelector('[data-hero-video]');

  if (heroSection instanceof HTMLElement && heroVideo instanceof HTMLVideoElement) {
    heroVideo.defaultMuted = true;
    heroVideo.muted = true;

    let inViewport = false;

    const ensureLoadStarted = () => {
      if (heroVideo.networkState === HTMLMediaElement.NETWORK_EMPTY) {
        heroVideo.load();
      }
    };

    const syncPlayback = async () => {
      if (!inViewport || document.hidden) {
        heroVideo.pause();
        return;
      }

      ensureLoadStarted();

      try {
        await heroVideo.play();
      } catch {
        heroVideo.pause();
      }
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const [entry] = entries;
        if (!entry) {
          return;
        }

        inViewport = entry.isIntersecting && entry.intersectionRatio > 0.05;
        void syncPlayback();
      },
      {
        threshold: [0, 0.05],
      },
    );

    observer.observe(heroSection);

    const initialBounds = heroSection.getBoundingClientRect();
    inViewport = initialBounds.top < window.innerHeight && initialBounds.bottom > 0;
    void syncPlayback();

    document.addEventListener('visibilitychange', () => {
      void syncPlayback();
    });

    heroVideo.addEventListener('canplay', () => {
      void syncPlayback();
    });

    window.addEventListener('pageshow', () => {
      void syncPlayback();
    });

    window.addEventListener('pagehide', () => {
      heroVideo.pause();
    });
  }
</script>

<script is:inline>
  (function() {
    var hint = document.querySelector('[data-scroll-hint]');
    if (!hint) return;

    var fadeEnd = 100;

    function update() {
      var y = window.pageYOffset || document.documentElement.scrollTop;
      if (y <= 0) {
        hint.style.opacity = '1';
        hint.style.pointerEvents = '';
      } else if (y >= fadeEnd) {
        hint.style.opacity = '0';
        hint.style.pointerEvents = 'none';
      } else {
        hint.style.opacity = String(1 - y / fadeEnd);
        hint.style.pointerEvents = '';
      }
    }

    window.addEventListener('scroll', update, { passive: true });
    update();
  })();
</script>

<script is:inline>
  document.querySelectorAll('[data-ph-capture]').forEach(function(el) {
    el.addEventListener('click', function() {
      var event = el.getAttribute('data-ph-capture');
      var propsStr = el.getAttribute('data-ph-props');
      var props = propsStr ? JSON.parse(propsStr) : {};
      window.posthog?.capture(event, props);
    });
  });
</script>
