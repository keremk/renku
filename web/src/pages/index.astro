---
import LandingLayout from '../layouts/LandingLayout.astro';
import Hero from '../components/Hero.astro';
import FeaturesSection from '../components/FeaturesSection.astro';
import IconArrowRight from '../components/icons/IconArrowRight.astro';
import IconGitHub from '../components/icons/IconGitHub.astro';
import HowItWorksPipeline from '../components/HowItWorksPipeline.astro';
---

<LandingLayout title="AI-Powered Movie Generation">
  <!-- Hero Section -->
  <Hero />

  <!-- Features Section -->
  <FeaturesSection />

  <!-- How It Works Section -->
  <HowItWorksPipeline />

  <!-- CTA Section -->
  <section class="py-20 px-4 max-w-6xl mx-auto">
    <div class="max-w-6xl mx-auto">
      <div class="cta-card">
        <!-- Decorative elements -->
        <div class="absolute rounded-full top-0 right-0 w-64 h-64 translate-x-1/2 -translate-y-1/2" style="background: rgba(255, 255, 255, 0.1); filter: blur(40px);"></div>
        <div class="absolute rounded-full bottom-0 left-0 w-48 h-48 -translate-x-1/2 translate-y-1/2" style="background: rgba(255, 255, 255, 0.1); filter: blur(40px);"></div>

        <div class="relative z-10">
          <h2 class="font-bold text-white mb-4" style="font-size: clamp(1.5rem, 4vw, 2.5rem);">
            Ready to create amazing videos?
          </h2>
          <p class="text-lg max-w-xl mx-auto mb-8" style="color: rgba(255, 255, 255, 0.8);">
            Start creating AI-powered videos today. Check out our documentation to learn more about what's possible.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/docs/" class="cta-btn-primary">
              Read the Docs
              <IconArrowRight class="ml-2 w-5 h-5" />
            </a>
            <a href="#github" class="cta-btn-secondary">
              <IconGitHub class="mr-2 w-5 h-5" />
              Star on GitHub
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</LandingLayout>

