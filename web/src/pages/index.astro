---
import LandingLayout from '../layouts/LandingLayout.astro';
import Hero from '../components/Hero.astro';
import FeaturesSection from '../components/FeaturesSection.astro';
import IconArrowRight from '../components/icons/IconArrowRight.astro';
import HowItWorksPipeline from '../components/HowItWorksPipeline.astro';
---

<LandingLayout title="AI-Powered Movie Generation">
  <!-- Hero Section -->
  <Hero />

  <!-- Features Section -->
  <FeaturesSection />

  <!-- How It Works Section -->
  <HowItWorksPipeline />

  <!-- CTA Section -->
  <section class="py-20 px-4 max-w-6xl mx-auto">
    <div class="max-w-6xl mx-auto">
      <div class="cta-card">
        <div class="relative z-10">
          <h2 class="font-extrabold mb-4" style="font-size: clamp(2rem, 5vw, 3rem); letter-spacing: -0.02em; line-height: 1.15; color: var(--color-foreground);">
            Ready to create amazing videos?
          </h2>
          <p class="text-lg max-w-xl mx-auto mb-8" style="color: var(--color-muted-foreground);">
            Get started on your platform with the install flow for macOS, Linux, and Windows (WSL).
          </p>
          <div class="hidden sm:flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/install/" class="cta-btn-primary" data-ph-capture="cta_section_install_clicked" data-ph-props='{"location":"cta_section"}'>
              Install
              <IconArrowRight class="ml-2 w-5 h-5" />
            </a>
            <!--
              Temporary while DMG signing is unavailable:
              <a href="https://downloads.gorenku.com/desktop/stable/darwin/arm64/Renku-latest-arm64.dmg" class="cta-btn-primary" target="_blank" rel="noreferrer">
                Download for macOS
                <IconArrowRight class="ml-2 w-5 h-5" />
              </a>
            -->
            <a href="/docs/app-quick-start" class="cta-btn-secondary" data-ph-capture="cta_section_quickstart_clicked" data-ph-props='{"location":"cta_section"}'>
              Open Quick Start
              <IconArrowRight class="ml-2 w-5 h-5" />
            </a>
          </div>
          <p class="hidden sm:block mt-4 text-sm" style="color: var(--color-muted-foreground);">
            Run <code>renku launch</code> after install to open onboarding and the viewer experience.
          </p>

          <div class="sm:hidden space-y-4">
            <p class="landing-mobile-note">
              Renku runs on desktop platforms. Use the install guide for macOS, Linux, and Windows with WSL.
            </p>
            <div class="flex flex-col gap-3">
              <a href="/install/" class="cta-btn-primary" data-ph-capture="cta_section_install_clicked" data-ph-props='{"location":"cta_section_mobile"}'>
                View install options
                <IconArrowRight class="ml-2 w-5 h-5" />
              </a>
              <a href="/docs/" class="cta-btn-secondary" data-ph-capture="cta_section_quickstart_clicked" data-ph-props='{"location":"cta_section_mobile","destination":"docs"}'>
                Read the Docs
                <IconArrowRight class="ml-2 w-5 h-5" />
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</LandingLayout>

<script is:inline>
  document.querySelectorAll('[data-ph-capture]').forEach(function(el) {
    el.addEventListener('click', function() {
      var event = el.getAttribute('data-ph-capture');
      var propsStr = el.getAttribute('data-ph-props');
      var props = propsStr ? JSON.parse(propsStr) : {};
      window.posthog?.capture(event, props);
    });
  });
</script>
