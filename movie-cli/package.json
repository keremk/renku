{
  "name": "@gorenku/movie-cli",
  "version": "0.1.0",
  "description": "Agent and human command surface for Renku Movie Studio projects",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "renku-movie": "dist/cli.js"
  },
  "type": "module",
  "engines": {
    "node": ">=16"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "test": "vitest run --pool=threads --poolOptions.threads.singleThread",
    "test:typecheck": "tsc --project tsconfig.vitest.json --noEmit",
    "check:all": "pnpm type-check && pnpm lint && pnpm test:typecheck",
    "test:ui": "vitest --ui",
    "test:run": "vitest run"
  },
  "files": [
    "dist"
  ],
  "packageManager": "pnpm@10.15.0",
  "dependencies": {
    "@gorenku/movie-core": "workspace:*"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.36.0",
    "@types/node": "^20.16.11",
    "@typescript-eslint/parser": "^8.18.2",
    "@vitest/ui": "^3.2.4",
    "eslint": "^8",
    "eslint-config-prettier": "^10.1.8",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  }
}
