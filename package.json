{
  "name": "renku-monorepo",
  "version": "1.0.0",
  "type": "module",
  "license": "SEE LICENSE IN each package directory",
  "workspaces": [
    "core",
    "cli",
    "compositions",
    "providers",
    "viewer",
    "web",
    "desktop"
  ],
  "scripts": {
    "dev:core": "pnpm --filter @gorenku/core dev",
    "dev:cli": "pnpm --filter @gorenku/cli dev",
    "dev:viewer": "pnpm --filter viewer dev",
    "dev:web": "pnpm --filter @gorenku/web dev",
    "build:workspace": "pnpm --filter @gorenku/core build && pnpm --filter @gorenku/compositions build && pnpm --filter @gorenku/providers build && pnpm --filter @gorenku/cli build && pnpm --filter viewer build",
    "build": "pnpm build:workspace && pnpm --filter renku-desktop build",
    "build:core": "pnpm --filter @gorenku/core build",
    "build:providers": "pnpm --filter @gorenku/providers build",
    "build:compositions": "pnpm --filter @gorenku/compositions build",
    "build:cli": "pnpm --filter @gorenku/cli build",
    "build:viewer": "pnpm --filter viewer build",
    "build:web": "pnpm --filter @gorenku/web build",
    "deploy:web": "pnpm --filter @gorenku/web cf-deploy",
    "lint": "pnpm --filter @gorenku/core lint && pnpm --filter @gorenku/providers lint && pnpm --filter @gorenku/cli lint && pnpm --filter viewer lint",
    "lint:core": "pnpm --filter @gorenku/core lint",
    "lint:providers": "pnpm --filter @gorenku/providers lint",
    "lint:cli": "pnpm --filter @gorenku/cli lint",
    "lint:viewer": "pnpm --filter viewer lint",
    "type-check": "pnpm --filter @gorenku/core type-check && pnpm --filter @gorenku/providers type-check && pnpm --filter @gorenku/cli type-check",
    "type-check:core": "pnpm --filter @gorenku/core type-check",
    "type-check:providers": "pnpm --filter @gorenku/providers type-check",
    "type-check:compositions": "pnpm --filter @gorenku/compositions type-check",
    "type-check:cli": "pnpm --filter @gorenku/cli type-check",
    "type-check:web": "pnpm --filter @gorenku/web type-check",
    "test": "pnpm --filter @gorenku/core test && pnpm --filter @gorenku/providers test && pnpm validate:producers && pnpm --filter @gorenku/cli test && pnpm --filter viewer test",
    "test:core": "pnpm --filter @gorenku/core test",
    "test:providers": "pnpm --filter @gorenku/providers test",
    "test:cli": "pnpm --filter @gorenku/cli test",
    "test:typecheck": "pnpm --filter @gorenku/core test:typecheck && pnpm --filter @gorenku/providers test:typecheck && pnpm --filter @gorenku/cli test:typecheck && pnpm --filter viewer test:typecheck",
    "test:typecheck:core": "pnpm --filter @gorenku/core test:typecheck",
    "test:typecheck:providers": "pnpm --filter @gorenku/providers test:typecheck",
    "test:typecheck:cli": "pnpm --filter @gorenku/cli test:typecheck",
    "test:typecheck:viewer": "pnpm --filter viewer test:typecheck",
    "test:viewer": "pnpm --filter viewer test",
    "validate:producers": "pnpm --filter @gorenku/providers validate:producers",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:all": "pnpm lint && pnpm format:check",
    "check": "pnpm type-check && pnpm test:typecheck && pnpm catalog:check",
    "bundle:viewer": "pnpm --filter viewer build && node scripts/prepare-viewer-bundle.mjs",
    "package:cli": "node scripts/package-cli.mjs",
    "bump": "bash scripts/bump-versions.sh",
    "bump:minor": "bash scripts/bump-versions.sh minor",
    "bump:major": "bash scripts/bump-versions.sh major",
    "release": "pnpm release:ship",
    "release:unsigned": "node scripts/release/ship.mjs patch --skip-desktop-sign",
    "release:minor": "pnpm release:ship:minor",
    "release:major": "pnpm release:ship:major",
    "release:ci": "pnpm release:ship",
    "release:prepare": "node scripts/release/prepare.mjs patch",
    "release:prepare:minor": "node scripts/release/prepare.mjs minor",
    "release:prepare:major": "node scripts/release/prepare.mjs major",
    "release:preflight": "node scripts/release/preflight.mjs",
    "release:publish": "node scripts/release/publish.mjs",
    "release:ship": "node scripts/release/ship.mjs patch",
    "release:ship:minor": "node scripts/release/ship.mjs minor",
    "release:ship:major": "node scripts/release/ship.mjs major",
    "release:web": "pnpm deploy:web",
    "catalog:fetch-fal": "node scripts/fetch-fal-schema.mjs",
    "catalog:update-fal": "node scripts/update-fal-catalog.mjs catalog/models/fal-ai/fal-ai.yaml",
    "bundle:catalog": "node scripts/prepare-catalog-bundle.mjs",
    "catalog:check": "node scripts/check-catalog-sync.mjs",
    "catalog:audit-mappings": "node scripts/audit-producer-mappings.mjs",
    "build:desktop": "pnpm build:workspace && node scripts/prepare-desktop-bundle.mjs && pnpm --filter renku-desktop build",
    "package:desktop": "pnpm build:desktop && pnpm --filter renku-desktop package",
    "package:desktop:dev": "pnpm build:desktop && pnpm --filter renku-desktop package:dev",
    "package:desktop:prod": "pnpm build:desktop && pnpm --filter renku-desktop package:prod",
    "dev:desktop": "pnpm --filter renku-desktop dev",
    "build-deploy-app": "bash scripts/deploy-desktop.sh --production",
    "build-deploy-app:dev": "bash scripts/deploy-desktop.sh --internal"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "concurrently": "^9.1.0",
    "esbuild": "^0.27.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "wrangler": "^4.73.0",
    "yaml": "^2.8.1"
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bufferutil",
      "esbuild",
      "sharp",
      "electron",
      "ffmpeg-static",
      "workerd",
      "electron-winstaller"
    ]
  }
}
